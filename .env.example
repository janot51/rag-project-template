# Copier vers .env et adapter à votre déploiement vLLM sur DGX Spark

# API vLLM (compatible OpenAI)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# Modèle principal (Qwen3.5 122B servi par vLLM)
LLM_MODEL=Qwen/Qwen3.5-122B-Instruct
VISION_MODEL=Qwen/Qwen3.5-122B-Instruct

# Embeddings — endpoint séparé si vous servez un modèle dédié
EMBEDDING_BASE_URL=http://localhost:8001/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096

# MinerU / parsing PDF (DGX Spark : cuda)
MINERU_DEVICE=cuda
PARSE_METHOD=auto
PARSER=mineru
