{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "vllm-gb10/Qwen/Qwen3.5-122B-Instruct",
  "instructions": [".kilo/rules/*.md"],
  "provider": {
    "vllm-gb10": {
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "apiKey": "EMPTY",
        "timeout": 3600000
      },
      "models": {
        "Qwen/Qwen3.5-122B-Instruct": {
          "name": "Qwen3.5 122B (vLLM local GB10)",
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "rag-reference": {
      "type": "local",
      "command": [
        "${workspaceFolder}/.venv/bin/python",
        "${workspaceFolder}/mcp_server/server.py"
      ],
      "environment": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "enabled": true,
      "timeout": 300000
    }
  },
  "permission": {
    "rag-reference_search_reference_docs": "allow",
    "rag-reference_get_index_status": "allow",
    "rag-reference_reindex_reference": "ask"
  }
}
